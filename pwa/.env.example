# Middleware base URL (BHNM proxy endpoint). Vite dev server proxies /bhnm/* here.
VITE_MIDDLEWARE_BASE=https://bhnm-apns.hurrikap.org

# BHNM API key (maps to servers.json entry in middleware). REQUIRED for real data.
VITE_BHNM_API_KEY=

# Optional BHNM PIN.
VITE_BHNM_PIN=

# 32-byte hex encryption key for QR code scanning.
# Auto-read from middleware/.env (BENEM_SECRET_KEY) at build time.
# Only set here to override the middleware value.
# VITE_QR_ENCRYPTION_KEY=
