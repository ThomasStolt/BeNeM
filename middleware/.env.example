# Copy this file to .env and fill in your values, or run ./setup.sh
# .env is gitignored — never commit it.

# ── APNs — from Apple Developer Portal ────────────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.tstolt.benem
APNS_USE_SANDBOX=true

# APNs private key (.p8) — base64 encoded
# Generate with: base64 -w 0 AuthKey_XXXXXX.p8
APNS_PRIVATE_KEY_B64=

# ── Domain — used by Caddy for automatic TLS (Let's Encrypt) ──────────────────
DOMAIN=bhnm-apns.example.com

# ── Authentication ─────────────────────────────────────────────────────────────
# Each BHNM server uses its own unique webhook secret for per-device routing.
# Configure the same secret in BHNM's webhook URL (?secret=YOUR_SECRET)
# and in BeNeM Settings → BHNM Server → Webhook Secret.
# Generate a unique secret per server with: openssl rand -hex 32
# (No WEBHOOK_SECRET variable needed — secrets are managed per-device/per-server)

# ── BHNM Proxy (for BeNeM API calls) ────────────────────────────────────────────
# BHNM_URL and PROXY_SECRET are no longer used.
# The target BHNM server is supplied per-request by the iOS app via X-BHNM-Target.
# The proxy token is supplied per-request via X-Proxy-Token.
# Set to false if any BHNM server uses a self-signed TLS certificate.
BHNM_TLS_VERIFY=true
