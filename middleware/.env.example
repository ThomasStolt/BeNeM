# Copy this file to .env and fill in your values, or run ./setup.sh
# .env is gitignored — never commit it.

# ── APNs — from Apple Developer Portal ────────────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.tstolt.benem

# APNs private key (.p8) — base64 encoded
# Generate with: base64 -w 0 AuthKey_XXXXXX.p8
APNS_PRIVATE_KEY_B64=

# ── Web Push (VAPID) — for PWA push notifications ───────────────────────────
# Generate VAPID key pair once:
#   python -c "from pywebpush import webpush; from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print('PRIVATE:', v.private_pem()); print('PUBLIC:', v.public_key)"
# Or use: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@example.com

# ── Domain — used by Caddy for automatic TLS (Let's Encrypt) ──────────────────
DOMAIN=bhnm-apns.example.com

# ── PWA Domain — second hostname served by Caddy for the static PWA bundle ───
# Must resolve to this server (A/AAAA record) before `docker compose up`, or
# Caddy's Let's Encrypt HTTP-01 challenge will fail. Same-origin API calls
# from the PWA go to https://$PWA_DOMAIN/bhnm/* and are proxied to bhnm-apns.
PWA_DOMAIN=benem.example.com

# ── Authentication ─────────────────────────────────────────────────────────────
# Each BHNM server uses its own unique webhook secret for per-device routing.
# Configure the same secret in BHNM's webhook URL (?secret=YOUR_SECRET)
# and in BeNeM Settings → BHNM Server → Webhook Secret.
# Generate a unique secret per server with: openssl rand -hex 32
# (No WEBHOOK_SECRET variable needed — secrets are managed per-device/per-server)

# ── BeNeM Admin portal ─────────────────────────────────────────────────────────
# BENEM_SECRET_KEY: 32-byte AES key for encrypting benem:// registration payloads.
# Generate with: openssl rand -hex 32  (must be exactly 64 hex characters)
BENEM_SECRET_KEY=

# SESSION_SECRET: REQUIRED — secret used to sign admin portal session cookies.
# Generate with: openssl rand -hex 32
# Must be set independently (does NOT fall back to BENEM_SECRET_KEY).
SESSION_SECRET=

# TOTP_SECRET: base32 secret for the admin portal TOTP authenticator.
# Generate with: python -c "import pyotp; print(pyotp.random_base32())"
# Then scan the QR code shown on the Settings page.
TOTP_SECRET=

# MIDDLEWARE_URL: public URL of this bhnm-apns instance (used in generated links).
# Example: https://bhnm-apns.example.com
MIDDLEWARE_URL=

# WEBHOOK_SECRET: default webhook secret embedded in generated registration links.
WEBHOOK_SECRET=

# ── BHNM Proxy (for BeNeM API calls) ────────────────────────────────────────────
# BHNM_URL and PROXY_SECRET are no longer used.
# The target BHNM server is supplied per-request by the iOS app via X-BHNM-Target.
# The proxy token is supplied per-request via X-Proxy-Token.
# Set to false if any BHNM server uses a self-signed TLS certificate.
BHNM_TLS_VERIFY=true

# Port the middleware listens on inside the container (default: 8889).
MIDDLEWARE_PORT=8889

# PROXY_TOKEN: token embedded in generated benem:// links, sent by the iOS app as
# X-Proxy-Token header on every BHNM API proxy request.
# Generate with: openssl rand -hex 32
PROXY_TOKEN=
