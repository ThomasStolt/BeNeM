# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Shared secret for webhook and device registration authentication.
# Must match the X-Webhook-Token header value configured in:
#   - BHNM webhook settings
#   - BeNeM app Settings → Push Notifications → Webhook Secret
# Use a strong random value, e.g.: openssl rand -hex 32
WEBHOOK_SECRET=
