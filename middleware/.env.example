# Copy this file to .env and fill in your values, or run ./setup.sh
# .env is gitignored — never commit it.

# APNs — from Apple Developer Portal
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.tstolt.benem
APNS_USE_SANDBOX=true

# APNs private key (.p8) — base64 encoded
# Generate with: base64 -w 0 AuthKey_XXXXXX.p8
APNS_PRIVATE_KEY_B64=

# Domain — used by Caddy for automatic TLS
DOMAIN=bhnm-apns.hurrikap.org

# Shared secret for webhook and device registration authentication.
# Must match the X-Webhook-Token header (or ?secret= query param) in BHNM,
# and the Webhook Secret field in BeNeM Settings.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=
